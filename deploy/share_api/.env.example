# Docker/Caddy or external reverse-proxy entrypoint for the optional LewisMD remote share API.
# The interactive installer in the next phase will write a real .env file
# based on these keys.

# Managed Caddy domain mode example:
# LEWISMD_SHARE_SITE_ADDRESS=shares.example.com
# LEWISMD_SHARE_PUBLIC_BASE=https://shares.example.com
# Cloudflare hardening for the recommended topology:
# - orange-cloud proxy the share hostname
# - set SSL/TLS mode to Full (strict)
# - add these rate-limit rules:
#   * /s/*, /snapshots/*, /assets/* => 240 requests / 60 seconds / client IP => Managed Challenge for 2 minutes
#   * /up, /api/v1/capabilities => 60 requests / 60 seconds / client IP => Block for 1 minute
#   * POST|PUT|DELETE /api/v1/* => 30 requests / 60 seconds / client IP => Block for 2 minutes
#
# Managed Caddy raw IP / HTTP mode example:
# LEWISMD_SHARE_SITE_ADDRESS=http://203.0.113.10:8080
# LEWISMD_SHARE_PUBLIC_BASE=http://203.0.113.10:8080
# External reverse proxy example:
# LEWISMD_SHARE_EDGE_MODE=external_reverse_proxy
# LEWISMD_SHARE_PUBLIC_SCHEME=https
# LEWISMD_SHARE_PUBLIC_HOST=shares.example.com
# LEWISMD_SHARE_PUBLIC_BASE=https://shares.example.com
LEWISMD_SHARE_EDGE_MODE=managed_caddy
LEWISMD_SHARE_PUBLIC_MODE=domain
LEWISMD_SHARE_PUBLIC_SCHEME=https
LEWISMD_SHARE_PUBLIC_HOST=shares.example.com
LEWISMD_SHARE_SITE_ADDRESS=shares.example.com
LEWISMD_SHARE_PUBLIC_BASE=https://shares.example.com

# Public host ports exposed by Caddy or the external reverse proxy.
LEWISMD_SHARE_HTTP_PORT=80
LEWISMD_SHARE_HTTPS_PORT=443
LEWISMD_SHARE_INTERNAL_PORT=9292

# Reverse proxy state and persisted share storage.
LEWISMD_SHARE_STORAGE_HOST_PATH=./data/storage
LEWISMD_SHARE_CADDY_DATA_PATH=./data/caddy-data
LEWISMD_SHARE_CADDY_CONFIG_PATH=./data/caddy-config

# Authentication between the local LewisMD app and the VPS share API.
LEWISMD_SHARE_API_TOKEN=change-me
LEWISMD_SHARE_SIGNING_SECRET=change-me

# Runtime limits.
LEWISMD_SHARE_MAX_PAYLOAD_BYTES=8000000
LEWISMD_SHARE_MAX_ASSET_BYTES=5000000
LEWISMD_SHARE_MAX_ASSET_COUNT=16
LEWISMD_SHARE_REPLAY_WINDOW_SECONDS=300
LEWISMD_SHARE_MAX_EXPIRATION_DAYS=365
LEWISMD_SHARE_EXPIRY_SWEEP_MINUTES=60

# Optional container tuning.
# LEWISMD_SHARE_PUMA_MAX_THREADS=5
# WEB_CONCURRENCY=1

# Optional host-side monitoring and outbound alerts.
# These are used by deploy/share_api/monitor_share_api.sh and the generated
# systemd timer units, not by the container directly.
LEWISMD_SHARE_INSTANCE_NAME=remote-share-vps
LEWISMD_SHARE_HEALTHCHECKS_PING_URL=
LEWISMD_SHARE_ALERT_WEBHOOK_KIND=
LEWISMD_SHARE_ALERT_WEBHOOK_URL=
LEWISMD_SHARE_ALERT_WEBHOOK_SECRET=
LEWISMD_SHARE_MONITOR_INTERVAL_MINUTES=5
LEWISMD_SHARE_MONITOR_DISK_THRESHOLD_PERCENT=90
LEWISMD_SHARE_MONITOR_SWEEPER_STALE_MINUTES=180
LEWISMD_SHARE_MONITOR_STORAGE_GROWTH_MB=250
