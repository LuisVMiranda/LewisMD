<% locale_names = {
  "en" => "English",
  "pt-BR" => "Português (Brasil)",
  "pt-PT" => "Português (Portugal)",
  "es" => "Español",
  "he" => "עברית",
  "ja" => "日本語",
  "ko" => "한국어"
} %>

<% content_for :title, "#{@share[:title]} | LewisMD Share" %>

<div
  class="share-view"
  data-controller="share-view"
  data-share-view-default-width-value="72"
  data-share-view-default-zoom-value="100"
  data-share-view-title-value="<%= @share[:title] %>"
  data-share-view-locale-value="<%= I18n.locale %>"
  data-share-view-updated-at-value="<%= @share[:updated_at].to_s %>"
  data-share-view-last-updated-template-value="<%= t("share_view.last_updated", timestamp: "%{timestamp}") %>"
  data-share-view-show-controls-label-value="<%= t("share_view.show_controls", default: "Show reading controls") %>"
  data-share-view-hide-controls-label-value="<%= t("share_view.hide_controls", default: "Hide reading controls") %>"
>
  <header class="share-view__toolbar">
    <div class="share-view__toolbar-top">
      <div class="share-view__identity">
        <p class="share-view__eyebrow"><%= t("share_view.label", default: "Shared note") %></p>
        <div class="share-view__title-row">
          <h1 class="share-view__title"><%= @share[:title] %></h1>
          <span class="share-view__updated-pill" data-share-view-target="updatedAtPill" hidden></span>
        </div>
      </div>

      <%= render "shares/toolbar_actions",
        initial_theme: @initial_theme,
        locale: I18n.locale,
        locale_names: locale_names %>
    </div>

    <%= render "shares/display_panel" %>
  </header>

  <main class="share-view__content">
    <iframe
      src="<%= @snapshot_url %>"
      class="share-view__frame"
      title="<%= t("share_view.iframe_title", default: "Shared note preview") %>"
      loading="eager"
      data-share-view-target="frame"
      data-action="load->share-view#onFrameLoad"
    ></iframe>
  </main>
</div>
