<% locale_names = {
  "en" => "English",
  "pt-BR" => "Português (Brasil)",
  "pt-PT" => "Português (Portugal)",
  "es" => "Español",
  "he" => "עברית",
  "ja" => "日本語",
  "ko" => "한국어"
} %>

<% content_for :title, "#{@share[:title]} | LewisMD Share" %>

<div
  class="share-view"
  data-controller="share-view"
  data-share-view-default-width-value="72"
  data-share-view-default-zoom-value="100"
  data-share-view-title-value="<%= @share[:title] %>"
>
  <header class="share-view__toolbar" data-share-view-target="toolbar">
    <div class="share-view__identity">
      <p class="share-view__eyebrow"><%= t("share_view.label", default: "Shared note") %></p>
      <h1 class="share-view__title"><%= @share[:title] %></h1>
    </div>

    <div class="share-view__controls">
      <div class="relative" data-controller="theme" data-theme-initial-value="<%= @initial_theme %>" data-theme-persist-value="false" data-theme-query-param-value="true" data-theme-allow-omarchy-value="false">
        <button
          type="button"
          data-action="click->theme#toggle"
          class="share-view__toolbar-button"
          title="<%= t('header.change_theme') %>"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
          </svg>
          <span class="text-xs" data-theme-target="currentTheme">Light</span>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div
          class="hidden absolute right-0 mt-1 w-48 rounded-lg shadow-lg bg-[var(--theme-bg-secondary)] border border-[var(--theme-border)] py-1 z-50"
          data-theme-target="menu"
        ></div>
      </div>

      <div class="relative" data-controller="locale" data-locale-initial-value="<%= I18n.locale %>" data-locale-persist-value="false">
        <button
          type="button"
          data-action="click->locale#toggle"
          class="share-view__toolbar-button"
          title="<%= t('header.change_language') %>"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
          </svg>
          <span class="text-xs" data-locale-target="currentLocale"><%= locale_names.fetch(I18n.locale.to_s, "English") %></span>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div
          class="hidden absolute right-0 mt-1 w-48 rounded-lg shadow-lg bg-[var(--theme-bg-secondary)] border border-[var(--theme-border)] py-1 z-50"
          data-locale-target="menu"
        ></div>
      </div>

      <%= render "notes/export_menu",
        selection_action: "export-menu:selected->share-view#onExportMenuSelected",
        shareable: false,
        markdown_copyable: false,
        button_class: "share-view__toolbar-button",
        button_label: t("header.exports"),
        menu_title: t("share_view.open_exports", default: "Open export actions") %>

      <div class="share-view__group">
        <span class="share-view__group-label"><%= t("share_view.zoom", default: "Zoom") %></span>
        <button
          type="button"
          class="share-view__button"
          title="<%= t("share_view.zoom_out", default: "Zoom out") %>"
          data-action="share-view#zoomOut"
        >
          -
        </button>
        <output class="share-view__value" data-share-view-target="zoomValue">100%</output>
        <button
          type="button"
          class="share-view__button"
          title="<%= t("share_view.zoom_in", default: "Zoom in") %>"
          data-action="share-view#zoomIn"
        >
          +
        </button>
      </div>

      <div class="share-view__group">
        <span class="share-view__group-label"><%= t("share_view.width", default: "Width") %></span>
        <button
          type="button"
          class="share-view__button"
          title="<%= t("share_view.width_narrower", default: "Make text column narrower") %>"
          data-action="share-view#decreaseWidth"
        >
          -
        </button>
        <output class="share-view__value" data-share-view-target="widthValue">72ch</output>
        <button
          type="button"
          class="share-view__button"
          title="<%= t("share_view.width_wider", default: "Make text column wider") %>"
          data-action="share-view#increaseWidth"
        >
          +
        </button>
      </div>

      <label class="share-view__group share-view__font-group">
        <span class="share-view__group-label"><%= t("share_view.font_family", default: "Font") %></span>
        <select
          class="share-view__select"
          data-action="change->share-view#changeFontFamily"
          data-share-view-target="fontSelect"
        >
          <option value="default"><%= t("share_view.font_default", default: "Default") %></option>
          <option value="sans"><%= t("share_view.font_sans", default: "Sans") %></option>
          <option value="serif"><%= t("share_view.font_serif", default: "Serif") %></option>
          <option value="mono"><%= t("share_view.font_mono", default: "Mono") %></option>
        </select>
      </label>
    </div>
  </header>

  <main class="share-view__content">
    <iframe
      src="<%= @snapshot_url %>"
      class="share-view__frame"
      title="<%= t("share_view.iframe_title", default: "Shared note preview") %>"
      loading="eager"
      data-share-view-target="frame"
      data-action="load->share-view#onFrameLoad"
    ></iframe>
  </main>
</div>
