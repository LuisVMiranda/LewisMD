<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="h-full" data-theme="<%= @initial_theme || 'light' %>">
  <head>
    <title><%= content_for(:title) || "LewisMD Share" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex">
    <%= csrf_meta_tags %>

    <%= yield :head %>

    <link rel="icon" type="image/svg+xml" href="/icon.svg">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">

    <%= stylesheet_link_tag "fonts" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-[var(--theme-bg-secondary)] text-[var(--theme-text-primary)] font-sans antialiased">
    <%= yield %>
  </body>
</html>
