<header class="flex-none h-12 border-b border-[var(--theme-border)] flex items-center px-4 bg-[var(--theme-bg-secondary)]">
  <!-- Left: Sidebar toggle + App name -->
  <div class="flex items-center gap-2 shrink-0">
    <!-- Sidebar Toggle (Burger Menu) -->
    <button
      type="button"
      data-action="click->app#toggleSidebar"
      data-app-target="sidebarToggle"
      class="p-1.5 rounded hover:bg-[var(--theme-bg-hover)] text-[var(--theme-text-muted)]"
      title="<%= t('header.toggle_explorer') %>"
      aria-expanded="true"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
    <button
      type="button"
      data-action="click->app#openAboutDialog"
      class="flex items-center gap-2 p-1 rounded hover:bg-[var(--theme-bg-hover)] transition-colors"
      title="<%= t('header.about_app') %>"
    >
<img src="/icon.svg" class="w-5 h-5" alt="<%= t('app.name') %>">
      <span class="font-semibold text-sm"><%= t('app.name') %></span>
    </button>
  </div>

  <!-- Center: Current file path (truncates from left with ... when overflowing) -->
  <div class="flex-1 min-w-0 mx-3 flex items-center gap-2">
    <div
      class="path-container relative cursor-pointer"
      data-controller="path-display"
      data-action="click->path-display#copy mouseenter->path-display#showFull mouseleave->path-display#hideFull"
      title="<%= t('header.click_to_copy_path') %>"
    >
      <span
        class="path-text text-sm text-[var(--theme-text-muted)] whitespace-nowrap"
        data-path-display-target="text"
        data-app-target="currentPath"
      ><%= t('editor.select_note') %></span>
    </div>
    <span class="text-xs text-[var(--theme-text-faint)] hidden shrink-0" data-autosave-target="saveStatus"></span>
  </div>

  <div class="flex items-center gap-2 shrink-0">
    <button
      type="button"
      data-action="click->app#toggleTypewriterMode"
      data-typewriter-target="toggleButton"
      data-typewriter-mode-btn
      class="p-1.5 rounded hover:bg-[var(--theme-bg-hover)] text-[var(--theme-text-muted)]"
      title="<%= t('header.toggle_typewriter') %>"
      aria-pressed="false"
    >
      <!-- Typewriter icon -->
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <rect x="3" y="14" width="18" height="7" rx="1" />
        <rect x="5" y="7" width="14" height="7" rx="1" />
        <circle cx="8" cy="17" r="1" fill="currentColor" />
        <circle cx="12" cy="17" r="1" fill="currentColor" />
        <circle cx="16" cy="17" r="1" fill="currentColor" />
        <path d="M9 4h6" stroke-linecap="round" />
        <path d="M12 4v3" stroke-linecap="round" />
      </svg>
    </button>
    <button
      type="button"
      data-action="click->app#togglePreview"
      data-app-target="previewToggle"
      class="p-1.5 rounded hover:bg-[var(--theme-bg-hover)] text-[var(--theme-text-muted)]"
      title="<%= t('header.toggle_preview') %>"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
      </svg>
    </button>
    <button
      type="button"
      data-action="click->app#toggleReadingMode"
      data-app-target="readingModeToggle"
      class="p-1.5 rounded hover:bg-[var(--theme-bg-hover)] text-[var(--theme-text-muted)]"
      title="Toggle Reading Mode (Ctrl+Shift+Y)"
      aria-pressed="false"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
      </svg>
    </button>
    <!-- Theme Picker -->
    <div class="relative" data-controller="theme" data-theme-initial-value="<%= @config&.dig(:settings, 'theme') %>">
      <button
        type="button"
        data-action="click->theme#toggle"
        class="flex items-center gap-1.5 px-2 py-1.5 rounded hover:bg-[var(--theme-bg-hover)] text-[var(--theme-text-muted)]"
        title="<%= t('header.change_theme') %>"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
        </svg>
        <span class="text-xs" data-theme-target="currentTheme">Light</span>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <!-- Theme dropdown menu -->
      <div
        class="hidden absolute right-0 mt-1 w-48 rounded-lg shadow-lg bg-[var(--theme-bg-secondary)] border border-[var(--theme-border)] py-1 z-50"
        data-theme-target="menu"
      >
        <!-- Menu items rendered by JavaScript -->
      </div>
    </div>
    <!-- Language Picker -->
    <div class="relative" data-controller="locale" data-locale-initial-value="<%= @config&.dig(:settings, 'locale') || I18n.locale %>">
      <button
        type="button"
        data-action="click->locale#toggle"
        class="flex items-center gap-1.5 px-2 py-1.5 rounded hover:bg-[var(--theme-bg-hover)] text-[var(--theme-text-muted)]"
        title="<%= t('header.change_language') %>"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
        </svg>
        <span class="text-xs" data-locale-target="currentLocale"><%= I18n.locale == :'pt-BR' ? 'Portugues' : 'English' %></span>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <!-- Language dropdown menu -->
      <div
        class="hidden absolute right-0 mt-1 w-48 rounded-lg shadow-lg bg-[var(--theme-bg-secondary)] border border-[var(--theme-border)] py-1 z-50"
        data-locale-target="menu"
      >
        <!-- Menu items rendered by JavaScript -->
      </div>
    </div>
    <button
      type="button"
      data-action="click->app#copyHtmlToClipboard"
      class="p-1.5 rounded hover:bg-[var(--theme-bg-hover)] text-[var(--theme-text-muted)]"
      title="Copy as Rich Text (HTML)"
      id="copy-html-btn"
    >
      <!-- Clipboard icon -->
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184" />
      </svg>
    </button>
    <button
      type="button"
      data-action="click->app#printNote"
      class="p-1.5 rounded hover:bg-[var(--theme-bg-hover)] text-[var(--theme-text-muted)]"
      title="Export as PDF (Print)"
      id="print-note-btn"
    >
      <!-- Printer icon -->
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.056 48.056 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5zm-3 0h.008v.008H15V10.5z" />
      </svg>
    </button>
  </div>
</header>
