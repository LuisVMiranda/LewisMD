<div class="status-strip hidden"
     data-status-strip-target="strip"
     aria-live="polite"
     role="status">
  <div class="status-strip__group">
    <span class="status-strip__chip"
          data-status-strip-target="modeChip"></span>
    <span class="status-strip__chip hidden"
          data-status-strip-target="saveChip"></span>
    <span class="status-strip__chip hidden"
          data-status-strip-target="recoveryChip"></span>
  </div>

  <div class="status-strip__group status-strip__group--metrics">
    <span class="status-strip__metric hidden"
          data-status-strip-target="lineMetric"></span>
    <span class="status-strip__metric hidden"
          data-status-strip-target="selectionMetric"></span>
    <span class="status-strip__metric hidden"
          data-status-strip-target="zoomMetric"></span>
  </div>
</div>
