<!-- File Operations - Context Menu and Dialogs -->
<div data-controller="file-operations"
     data-file-operations-backup-note-label-value="<%= t('context_menu.backup_note', default: 'Back up note') %>"
     data-file-operations-backup-folder-label-value="<%= t('context_menu.backup_folder', default: 'Back up folder') %>"
     data-file-operations-backup-preparing-message-value="<%= t('status.backup_preparing', default: 'Preparing backup...') %>"
     data-file-operations-backup-started-message-value="<%= t('status.backup_started', default: 'Backup download started') %>"
     data-file-operations-backup-failed-message-value="<%= t('status.backup_failed', default: 'Failed to download backup') %>"
     data-action="file-operations:file-created->app#onFileCreated file-operations:folder-created->app#onFolderCreated file-operations:file-renamed->app#onFileRenamed file-operations:file-deleted->app#onFileDeleted file-operations:status-message->app#onFileOperationsStatusMessage">

  <!-- Context Menu -->
  <div
    class="fixed hidden bg-[var(--theme-bg-secondary)] border border-[var(--theme-border)] rounded-lg shadow-lg py-1 min-w-[160px] z-50 text-[var(--theme-text-primary)]"
    data-file-operations-target="contextMenu"
    data-app-target="contextMenu"
  >
    <button
      type="button"
      data-action="click->file-operations#newNoteInFolder"
      class="hidden w-full px-3 py-1.5 text-left text-sm hover:bg-[var(--theme-bg-hover)] flex items-center gap-2"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <%= t('context_menu.new_note') %>
    </button>
    <button
      type="button"
      data-action="click->file-operations#newFolderInFolder"
      class="hidden w-full px-3 py-1.5 text-left text-sm hover:bg-[var(--theme-bg-hover)] flex items-center gap-2"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m-2-13H5a2 2 0 00-2 2v12a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-6l-2-2z" />
      </svg>
      <%= t('context_menu.new_folder') %>
    </button>
    <button
      type="button"
      data-action="click->file-operations#renameItem"
      class="w-full px-3 py-1.5 text-left text-sm hover:bg-[var(--theme-bg-hover)] flex items-center gap-2"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
      </svg>
      <%= t('context_menu.rename') %>
    </button>
    <button
      type="button"
      data-file-operations-target="copyPathMenuItem"
      data-action="click->file-operations#copyItemPath"
      class="hidden w-full px-3 py-1.5 text-left text-sm hover:bg-[var(--theme-bg-hover)] flex items-center gap-2"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-4 12h4a2 2 0 002-2v-8a2 2 0 00-2-2h-4a2 2 0 00-2 2v8a2 2 0 002 2z" />
      </svg>
      <%= t('context_menu.copy_as_path') %>
    </button>
    <button
      type="button"
      data-file-operations-target="templateNoteMenuItem"
      data-action="click->file-operations#handleTemplateContextAction"
      class="hidden w-full px-3 py-1.5 text-left text-sm hover:bg-[var(--theme-bg-hover)] flex items-center gap-2"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h10M7 12h10M7 17h6M5 3h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2z" />
      </svg>
      <span data-file-operations-target="templateNoteMenuLabel"><%= t('context_menu.save_as_template') %></span>
    </button>
    <button
      type="button"
      data-file-operations-target="backupMenuItem"
      data-action="click->file-operations#downloadBackup"
      class="hidden w-full px-3 py-1.5 text-left text-sm hover:bg-[var(--theme-bg-hover)] flex items-center gap-2"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 16V4m0 12l-4-4m4 4l4-4M5 20h14" />
      </svg>
      <span data-file-operations-target="backupMenuLabel"><%= t('context_menu.backup_note', default: 'Back up note') %></span>
    </button>
    <button
      type="button"
      data-action="click->file-operations#deleteItem"
      class="w-full px-3 py-1.5 text-left text-sm hover:bg-[var(--theme-bg-hover)] flex items-center gap-2 text-[var(--theme-error)]"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
      </svg>
      <%= t('context_menu.delete') %>
    </button>
  </div>

  <!-- Rename Dialog -->
  <dialog
    class="p-0 rounded-lg shadow-xl backdrop:bg-black/50 bg-[var(--theme-bg-secondary)] border border-[var(--theme-border)]"
    data-file-operations-target="renameDialog"
  >
    <form method="dialog" class="p-4 w-80 text-[var(--theme-text-primary)]">
      <h3 class="text-sm font-semibold mb-3"><%= t('dialogs.rename.title') %></h3>
      <input
        type="text"
        data-file-operations-target="renameInput"
        data-action="keydown->file-operations#onRenameKeydown"
        class="w-full px-3 py-2 text-sm border border-[var(--theme-border)] rounded-md bg-[var(--theme-bg-primary)] text-[var(--theme-text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--theme-accent)]"
        placeholder="<%= t('dialogs.rename.placeholder') %>"
      >
      <div class="flex justify-end gap-2 mt-4">
        <%= render "shared/button_secondary", label: t('common.cancel'), action: "click->file-operations#closeRenameDialog" %>
        <%= render "shared/button_primary", label: t('common.rename'), action: "click->file-operations#submitRename" %>
      </div>
    </form>
  </dialog>

  <!-- Save Note as Template Dialog -->
  <dialog
    class="p-0 rounded-lg shadow-xl backdrop:bg-black/50 bg-[var(--theme-bg-secondary)] border border-[var(--theme-border)]"
    data-file-operations-target="saveTemplateDialog"
  >
    <form method="dialog" class="p-4 w-96 max-w-[90vw] text-[var(--theme-text-primary)]">
      <h3 class="text-sm font-semibold mb-1" data-file-operations-target="saveTemplateTitle"><%= t('dialogs.templates.save_from_note_title') %></h3>
      <p class="text-xs text-[var(--theme-text-muted)] mb-3" data-file-operations-target="saveTemplateNotePath"></p>
      <label class="block text-xs font-medium text-[var(--theme-text-secondary)] mb-1">
        <%= t('dialogs.templates.path_label') %>
      </label>
      <input
        type="text"
        data-file-operations-target="saveTemplateInput"
        data-action="keydown->file-operations#onSaveTemplateKeydown"
        class="w-full px-3 py-2 text-sm border border-[var(--theme-border)] rounded-md bg-[var(--theme-bg-primary)] text-[var(--theme-text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--theme-accent)]"
        placeholder="<%= t('dialogs.templates.path_placeholder') %>"
      >
      <div class="flex justify-end gap-2 mt-4">
        <%= render "shared/button_secondary", label: t('common.cancel'), action: "click->file-operations#closeSaveTemplateDialog" %>
        <%= render "shared/button_primary", label: t('common.save'), action: "click->file-operations#submitSaveTemplateFromNote" %>
      </div>
    </form>
  </dialog>

  <!-- Note Type Dialog -->
  <dialog
    class="p-0 rounded-lg shadow-xl backdrop:bg-black/50 bg-[var(--theme-bg-secondary)] border border-[var(--theme-border)]"
    data-file-operations-target="noteTypeDialog"
  >
    <div class="p-4 w-72 text-[var(--theme-text-primary)]">
      <h3 class="text-sm font-semibold mb-3"><%= t('dialogs.note_type.title') %></h3>
      <div class="flex flex-col gap-2">
        <button
          type="button"
          data-action="click->file-operations#selectNoteTypeEmpty"
          class="w-full px-3 py-2.5 text-left text-sm rounded-md hover:bg-[var(--theme-bg-hover)] flex items-center gap-3 border border-[var(--theme-border)]"
        >
          <svg class="w-5 h-5 text-[var(--theme-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <div>
            <div class="font-medium"><%= t('dialogs.note_type.empty_document') %></div>
            <div class="text-xs text-[var(--theme-text-muted)]"><%= t('dialogs.note_type.empty_description') %></div>
          </div>
        </button>
        <button
          type="button"
          data-action="click->file-operations#selectNoteTypeTemplate"
          class="w-full px-3 py-2.5 text-left text-sm rounded-md hover:bg-[var(--theme-bg-hover)] flex items-center gap-3 border border-[var(--theme-border)]"
        >
          <svg class="w-5 h-5 text-[var(--theme-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h10M7 12h10M7 17h6M5 3h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2z" />
          </svg>
          <div>
            <div class="font-medium"><%= t('dialogs.note_type.template') %></div>
            <div class="text-xs text-[var(--theme-text-muted)]"><%= t('dialogs.note_type.template_description') %></div>
          </div>
        </button>
        <button
          type="button"
          data-action="click->file-operations#selectNoteTypeHugo"
          class="w-full px-3 py-2.5 text-left text-sm rounded-md hover:bg-[var(--theme-bg-hover)] flex items-center gap-3 border border-[var(--theme-border)]"
        >
          <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
          <div>
            <div class="font-medium"><%= t('dialogs.note_type.hugo_post') %></div>
            <div class="text-xs text-[var(--theme-text-muted)]"><%= t('dialogs.note_type.hugo_description') %></div>
          </div>
        </button>
      </div>
      <div class="flex justify-end mt-4">
        <%= render "shared/button_secondary", label: t('common.cancel'), action: "click->file-operations#closeNoteTypeDialog" %>
      </div>
    </div>
  </dialog>

  <!-- Template Picker Dialog -->
  <dialog
    class="p-0 rounded-lg shadow-xl backdrop:bg-black/50 bg-[var(--theme-bg-secondary)] border border-[var(--theme-border)]"
    data-file-operations-target="templateDialog"
  >
    <div class="p-4 w-[26rem] max-w-[90vw] text-[var(--theme-text-primary)]">
      <h3 class="text-sm font-semibold mb-1"><%= t('dialogs.templates.title') %></h3>
      <p class="text-xs text-[var(--theme-text-muted)] mb-3"><%= t('dialogs.templates.subtitle') %></p>

      <div data-file-operations-target="templateLoading" class="text-sm text-[var(--theme-text-muted)] py-4">
        <%= t('dialogs.templates.loading') %>
      </div>

      <div data-file-operations-target="templateEmpty" class="hidden text-sm text-[var(--theme-text-muted)] py-4">
        <%= t('dialogs.templates.empty') %>
      </div>

      <div
        data-file-operations-target="templateList"
        class="flex flex-col gap-2 max-h-80 overflow-y-auto pr-1"
      ></div>

      <div class="flex justify-end mt-4">
        <button
          type="button"
          data-action="click->file-operations#openTemplateManager"
          class="mr-auto px-3 py-1.5 text-sm rounded-md hover:bg-[var(--theme-bg-hover)] text-[var(--theme-text-secondary)]"
        >
          <%= t('dialogs.templates.manage_action') %>
        </button>
        <%= render "shared/button_secondary", label: t('common.cancel'), action: "click->file-operations#closeTemplateDialog" %>
      </div>
    </div>
  </dialog>

  <!-- Template Manager Dialog -->
  <dialog
    class="p-0 rounded-lg shadow-xl backdrop:bg-black/50 bg-[var(--theme-bg-secondary)] border border-[var(--theme-border)]"
    data-file-operations-target="templateManagerDialog"
  >
    <div class="p-4 w-[56rem] max-w-[95vw] text-[var(--theme-text-primary)]">
      <div class="flex items-start justify-between gap-4 mb-4">
        <div>
          <h3 class="text-sm font-semibold"><%= t('dialogs.templates.manage_title') %></h3>
          <p class="text-xs text-[var(--theme-text-muted)] mt-1"><%= t('dialogs.templates.manage_subtitle') %></p>
        </div>
        <div class="flex items-center gap-2">
          <button
            type="button"
            data-action="click->file-operations#newTemplate"
            class="px-3 py-1.5 text-sm rounded-md hover:bg-[var(--theme-bg-hover)] text-[var(--theme-text-secondary)]"
          >
            <%= t('dialogs.templates.new_button') %>
          </button>
          <button
            type="button"
            data-action="click->file-operations#refreshTemplateManager"
            class="px-3 py-1.5 text-sm rounded-md hover:bg-[var(--theme-bg-hover)] text-[var(--theme-text-secondary)]"
          >
            <%= t('dialogs.templates.refresh_button') %>
          </button>
        </div>
      </div>

      <div class="grid grid-cols-[18rem_minmax(0,1fr)] gap-4">
        <div
          data-file-operations-target="templateManagerList"
          class="max-h-[28rem] overflow-y-auto space-y-2 pr-1"
        ></div>

        <div class="border border-[var(--theme-border)] rounded-lg p-4 bg-[var(--theme-bg-primary)]">
          <h4 class="text-sm font-semibold mb-3" data-file-operations-target="templateFormTitle"><%= t('dialogs.templates.new_title') %></h4>

          <label class="block text-xs font-medium text-[var(--theme-text-secondary)] mb-1">
            <%= t('dialogs.templates.path_label') %>
          </label>
          <input
            type="text"
            data-file-operations-target="templatePathInput"
            class="w-full px-3 py-2 text-sm border border-[var(--theme-border)] rounded-md bg-[var(--theme-bg-secondary)] text-[var(--theme-text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--theme-accent)]"
            placeholder="<%= t('dialogs.templates.path_placeholder') %>"
          >

          <label class="block text-xs font-medium text-[var(--theme-text-secondary)] mt-4 mb-1">
            <%= t('dialogs.templates.content_label') %>
          </label>
          <textarea
            data-file-operations-target="templateContentInput"
            class="w-full min-h-[22rem] px-3 py-2 text-sm border border-[var(--theme-border)] rounded-md bg-[var(--theme-bg-secondary)] text-[var(--theme-text-primary)] font-mono focus:outline-none focus:ring-2 focus:ring-[var(--theme-accent)]"
            placeholder="<%= t('dialogs.templates.content_placeholder') %>"
          ></textarea>
        </div>
      </div>

      <div class="flex items-center justify-between gap-4 mt-4">
        <p
          data-file-operations-target="templateManagerNotice"
          class="hidden text-sm"
          aria-live="polite"
        ></p>

        <div class="flex justify-end gap-2">
          <button
            type="button"
            data-file-operations-target="templateDeleteButton"
            data-action="click->file-operations#deleteTemplate"
            class="hidden px-3 py-1.5 text-sm rounded-md hover:bg-[var(--theme-bg-hover)] text-[var(--theme-error)] disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <%= t('common.delete') %>
          </button>
          <button
            type="button"
            data-action="click->file-operations#closeTemplateManager"
            class="px-3 py-1.5 text-sm rounded-md hover:bg-[var(--theme-bg-hover)] text-[var(--theme-text-secondary)]"
          >
            <%= t('common.cancel') %>
          </button>
          <button
            type="button"
            data-file-operations-target="templateSaveButton"
            data-action="click->file-operations#submitTemplateSave"
            class="px-3 py-1.5 text-sm rounded-md bg-[var(--theme-accent)] text-[var(--theme-accent-text)] hover:bg-[var(--theme-accent-hover)] disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <%= t('common.save') %>
          </button>
        </div>
      </div>
    </div>
  </dialog>

  <!-- New Item Dialog -->
  <dialog
    class="p-0 rounded-lg shadow-xl backdrop:bg-black/50 bg-[var(--theme-bg-secondary)] border border-[var(--theme-border)]"
    data-file-operations-target="newItemDialog"
  >
    <form method="dialog" class="p-4 w-80 text-[var(--theme-text-primary)]">
      <h3 class="text-sm font-semibold mb-3" data-file-operations-target="newItemTitle"><%= t('dialogs.new_item.new_note') %></h3>
      <input
        type="text"
        data-file-operations-target="newItemInput"
        data-action="keydown->file-operations#onNewItemKeydown"
        class="w-full px-3 py-2 text-sm border border-[var(--theme-border)] rounded-md bg-[var(--theme-bg-primary)] text-[var(--theme-text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--theme-accent)]"
        placeholder="<%= t('dialogs.new_item.placeholder') %>"
      >
      <div class="flex justify-end gap-2 mt-4">
        <button
          type="button"
          data-action="click->file-operations#closeNewItemDialog"
          class="px-3 py-1.5 text-sm rounded-md hover:bg-[var(--theme-bg-hover)] text-[var(--theme-text-secondary)]"
        >
          <%= t('common.cancel') %>
        </button>
        <button
          type="button"
          data-action="click->file-operations#submitNewItem"
          class="px-3 py-1.5 text-sm rounded-md bg-[var(--theme-accent)] text-[var(--theme-accent-text)] hover:bg-[var(--theme-accent-hover)]"
        >
          <%= t('common.create') %>
        </button>
      </div>
    </form>
  </dialog>
</div>
