<div data-controller="share-management">
  <dialog
    data-share-management-target="dialog"
    data-action="click->share-management#onDialogClick keydown->share-management#onKeydown"
    class="w-[92vw] max-w-5xl p-0 rounded-lg shadow-xl bg-[var(--theme-bg-primary)] text-[var(--theme-text-primary)] backdrop:bg-black/50 border border-[var(--theme-border)]"
  >
    <div class="flex items-center justify-between px-6 py-4 border-b border-[var(--theme-border)]">
      <div>
        <h2 class="text-lg font-semibold"><%= t("share_management.title", default: "Manage API") %></h2>
        <p class="text-xs text-[var(--theme-text-muted)] mt-1"><%= t("share_management.subtitle", default: "Remote share relay settings, status, and maintenance.") %></p>
      </div>
      <%= render "shared/dialog_close_button", action: "click->share-management#close", size: "h-5 w-5", padding: "p-2", hover_bg: "hover:bg-[var(--theme-bg-secondary)]" %>
    </div>

    <div class="px-6 pt-4">
      <div class="inline-flex flex-wrap gap-2 rounded-lg border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] p-1.5">
        <button type="button"
                data-share-management-target="tabButton"
                data-tab="status"
                data-action="click->share-management#switchTab"
                class="rounded-md border px-4 py-1.5 text-sm transition-colors hover:bg-[var(--theme-bg-primary)]">
          <%= t("share_management.tabs.status", default: "Status") %>
        </button>
        <button type="button"
                data-share-management-target="tabButton"
                data-tab="connection"
                data-action="click->share-management#switchTab"
                class="rounded-md border px-4 py-1.5 text-sm transition-colors hover:bg-[var(--theme-bg-primary)]">
          <%= t("share_management.tabs.connection", default: "Connection") %>
        </button>
        <button type="button"
                data-share-management-target="tabButton"
                data-tab="publishing"
                data-action="click->share-management#switchTab"
                class="rounded-md border px-4 py-1.5 text-sm transition-colors hover:bg-[var(--theme-bg-primary)]">
          <%= t("share_management.tabs.publishing", default: "Publishing Overview") %>
        </button>
      </div>
    </div>

    <div class="p-6 space-y-6">
      <section data-share-management-target="tabPanel" data-tab-panel="status" class="space-y-4">
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wide text-[var(--theme-text-secondary)]"><%= t("share_management.status_heading", default: "Status") %></h3>
          <p class="text-xs text-[var(--theme-text-muted)] mt-1"><%= t("share_management.status_subtitle", default: "Check remote reachability, admin support, and cleanup readiness.") %></p>
        </div>
        <div data-share-management-target="statusPanel" class="rounded-lg border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] p-4 text-sm text-[var(--theme-text-primary)]">
          <%= t("share_management.loading", default: "Loading Share API settings...") %>
        </div>
      </section>

      <section data-share-management-target="tabPanel" data-tab-panel="connection" class="space-y-4 hidden">
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wide text-[var(--theme-text-secondary)]"><%= t("share_management.connection_heading", default: "Connection") %></h3>
          <p class="text-xs text-[var(--theme-text-muted)] mt-1"><%= t("share_management.secrets_hint", default: "Leave secret fields blank to keep the current value.") %></p>
        </div>

        <form data-share-management-target="form" class="grid grid-cols-3 gap-4">
          <details open class="group h-fit rounded-lg border border-[var(--theme-border)] bg-[var(--theme-bg-primary)]">
            <summary class="flex cursor-pointer list-none items-start justify-between gap-3 px-4 py-4 [&::-webkit-details-marker]:hidden">
              <div>
                <h4 class="text-[11px] uppercase tracking-wide text-[var(--theme-text-muted)]"><%= t("share_management.connection_groups.endpoint", default: "Endpoint") %></h4>
                <p class="mt-1 text-xs text-[var(--theme-text-muted)]"><%= t("share_management.connection_groups.endpoint_hint", default: "Core relay location and routing details.") %></p>
              </div>
              <span class="mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] text-[var(--theme-text-muted)] transition-colors group-hover:bg-[var(--theme-bg-hover)]">
                <svg class="h-4 w-4 transition-transform duration-200 group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.17l3.71-3.94a.75.75 0 011.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                </svg>
              </span>
            </summary>

            <div class="space-y-6 border-t border-[var(--theme-border)] px-4 py-5">
              <label class="block py-1">
                <span class="block pb-2.5 pt-1 text-xs font-medium text-[var(--theme-text-secondary)]"><%= t("share_management.fields.share_backend", default: "Share backend") %></span>
                <select
                  name="share_backend"
                  data-action="change->share-management#onBackendChanged"
                  class="w-full rounded border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-3 py-3 text-sm text-[var(--theme-text-primary)] focus:outline-none focus:ring-1 focus:ring-[var(--theme-accent)]"
                >
                  <option value="local">local</option>
                  <option value="remote">remote</option>
                </select>
              </label>

              <label class="block py-1">
                <span class="block pb-2.5 pt-1 text-xs font-medium text-[var(--theme-text-secondary)]"><%= t("share_management.fields.share_remote_api_scheme", default: "API scheme") %></span>
                <select
                  name="share_remote_api_scheme"
                  class="w-full rounded border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-3 py-3 text-sm text-[var(--theme-text-primary)] focus:outline-none focus:ring-1 focus:ring-[var(--theme-accent)]"
                >
                  <option value="https">https</option>
                  <option value="http">http</option>
                </select>
              </label>

              <label class="block py-1">
                <span class="block pb-2.5 pt-1 text-xs font-medium text-[var(--theme-text-secondary)]"><%= t("share_management.fields.share_remote_api_host", default: "API host") %></span>
                <input name="share_remote_api_host" type="text" class="w-full rounded border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-3 py-3 text-sm text-[var(--theme-text-primary)] focus:outline-none focus:ring-1 focus:ring-[var(--theme-accent)]">
              </label>

              <label class="block py-1">
                <span class="block pb-2.5 pt-1 text-xs font-medium text-[var(--theme-text-secondary)]"><%= t("share_management.fields.share_remote_api_port", default: "API port") %></span>
                <input name="share_remote_api_port" type="number" min="1" class="w-full rounded border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-3 py-3 text-sm text-[var(--theme-text-primary)] focus:outline-none focus:ring-1 focus:ring-[var(--theme-accent)]">
              </label>

              <label class="block py-1">
                <span class="block pb-2.5 pt-1 text-xs font-medium text-[var(--theme-text-secondary)]"><%= t("share_management.fields.share_remote_public_base", default: "Public base URL") %></span>
                <input name="share_remote_public_base" type="url" class="w-full rounded border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-3 py-3 text-sm text-[var(--theme-text-primary)] focus:outline-none focus:ring-1 focus:ring-[var(--theme-accent)]">
              </label>
            </div>
          </details>

          <details open class="group h-fit rounded-lg border border-[var(--theme-border)] bg-[var(--theme-bg-primary)]">
            <summary class="flex cursor-pointer list-none items-start justify-between gap-3 px-4 py-4 [&::-webkit-details-marker]:hidden">
              <div>
                <h4 class="text-[11px] uppercase tracking-wide text-[var(--theme-text-muted)]"><%= t("share_management.connection_groups.behavior", default: "Behavior") %></h4>
                <p class="mt-1 text-xs text-[var(--theme-text-muted)]"><%= t("share_management.connection_groups.behavior_hint", default: "Publishing defaults, timeouts, and observability hooks.") %></p>
              </div>
              <span class="mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] text-[var(--theme-text-muted)] transition-colors group-hover:bg-[var(--theme-bg-hover)]">
                <svg class="h-4 w-4 transition-transform duration-200 group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.17l3.71-3.94a.75.75 0 011.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                </svg>
              </span>
            </summary>

            <div class="space-y-6 border-t border-[var(--theme-border)] px-4 py-5">
              <label class="block py-1">
                <span class="block pb-2.5 pt-1 text-xs font-medium text-[var(--theme-text-secondary)]"><%= t("share_management.fields.share_remote_timeout_seconds", default: "Timeout (seconds)") %></span>
                <input name="share_remote_timeout_seconds" type="number" min="1" class="w-full rounded border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-3 py-3 text-sm text-[var(--theme-text-primary)] focus:outline-none focus:ring-1 focus:ring-[var(--theme-accent)]">
              </label>

              <label class="block py-1">
                <span class="block pb-2.5 pt-1 text-xs font-medium text-[var(--theme-text-secondary)]"><%= t("share_management.fields.share_remote_expiration_days", default: "Default expiration (days)") %></span>
                <input name="share_remote_expiration_days" type="number" min="0" class="w-full rounded border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-3 py-3 text-sm text-[var(--theme-text-primary)] focus:outline-none focus:ring-1 focus:ring-[var(--theme-accent)]">
              </label>

              <label class="block py-1">
                <span class="block pb-2.5 pt-1 text-xs font-medium text-[var(--theme-text-secondary)]"><%= t("share_management.fields.share_remote_instance_name", default: "Instance name") %></span>
                <input name="share_remote_instance_name" type="text" class="w-full rounded border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-3 py-3 text-sm text-[var(--theme-text-primary)] focus:outline-none focus:ring-1 focus:ring-[var(--theme-accent)]">
              </label>

              <label class="block py-1">
                <span class="block pb-2.5 pt-1 text-xs font-medium text-[var(--theme-text-secondary)]"><%= t("share_management.fields.share_remote_healthchecks_ping_url", default: "Healthchecks ping URL") %></span>
                <input name="share_remote_healthchecks_ping_url" type="url" class="w-full rounded border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-3 py-3 text-sm text-[var(--theme-text-primary)] focus:outline-none focus:ring-1 focus:ring-[var(--theme-accent)]">
              </label>

              <label class="block py-1">
                <span class="block pb-2.5 pt-1 text-xs font-medium text-[var(--theme-text-secondary)]"><%= t("share_management.fields.share_remote_alert_webhook_url", default: "Alert webhook URL") %></span>
                <input name="share_remote_alert_webhook_url" type="url" class="w-full rounded border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-3 py-3 text-sm text-[var(--theme-text-primary)] focus:outline-none focus:ring-1 focus:ring-[var(--theme-accent)]">
              </label>
            </div>
          </details>

          <details open class="group h-fit rounded-lg border border-[var(--theme-border)] bg-[var(--theme-bg-primary)]">
            <summary class="flex cursor-pointer list-none items-start justify-between gap-3 px-4 py-4 [&::-webkit-details-marker]:hidden">
              <div>
                <h4 class="text-[11px] uppercase tracking-wide text-[var(--theme-text-muted)]"><%= t("share_management.connection_groups.security", default: "Security") %></h4>
                <p class="mt-1 text-xs text-[var(--theme-text-muted)]"><%= t("share_management.connection_groups.security_hint", default: "Secrets and transport-related publishing controls.") %></p>
              </div>
              <span class="mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] text-[var(--theme-text-muted)] transition-colors group-hover:bg-[var(--theme-bg-hover)]">
                <svg class="h-4 w-4 transition-transform duration-200 group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.17l3.71-3.94a.75.75 0 011.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                </svg>
              </span>
            </summary>

            <div class="space-y-6 border-t border-[var(--theme-border)] px-4 py-5">
              <label class="block py-1">
                <span class="block pb-2.5 pt-1 text-xs font-medium text-[var(--theme-text-secondary)]"><%= t("share_management.fields.share_remote_api_token", default: "API token") %></span>
                <input name="share_remote_api_token" data-secret-setting="true" type="password" autocomplete="new-password" class="w-full rounded border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-3 py-3 text-sm text-[var(--theme-text-primary)] focus:outline-none focus:ring-1 focus:ring-[var(--theme-accent)]">
              </label>

              <label class="block py-1">
                <span class="block pb-2.5 pt-1 text-xs font-medium text-[var(--theme-text-secondary)]"><%= t("share_management.fields.share_remote_signing_secret", default: "Signing secret") %></span>
                <input name="share_remote_signing_secret" data-secret-setting="true" type="password" autocomplete="new-password" class="w-full rounded border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-3 py-3 text-sm text-[var(--theme-text-primary)] focus:outline-none focus:ring-1 focus:ring-[var(--theme-accent)]">
              </label>

              <label class="block py-1">
                <span class="block pb-2.5 pt-1 text-xs font-medium text-[var(--theme-text-secondary)]"><%= t("share_management.fields.share_remote_alert_webhook_secret", default: "Alert webhook secret") %></span>
                <input name="share_remote_alert_webhook_secret" data-secret-setting="true" type="password" autocomplete="new-password" class="w-full rounded border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-3 py-3 text-sm text-[var(--theme-text-primary)] focus:outline-none focus:ring-1 focus:ring-[var(--theme-accent)]">
              </label>

              <div class="rounded border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-3 py-4 text-sm text-[var(--theme-text-secondary)]">
                <p class="font-medium text-[var(--theme-text-primary)]"><%= t("share_management.tls_enforced_title", default: "TLS verification is always enforced") %></p>
                <p class="mt-1 text-xs text-[var(--theme-text-muted)]"><%= t("share_management.tls_enforced_hint", default: "LewisMD now verifies HTTPS certificates automatically for remote share publishing. Older insecure TLS overrides are treated as warnings and rewritten on the next save.") %></p>
              </div>

              <label class="flex items-center gap-3 rounded border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-3 py-3">
                <input name="share_remote_upload_assets" type="checkbox" class="rounded border-[var(--theme-border)] text-[var(--theme-accent)] focus:ring-[var(--theme-accent)]">
                <span class="text-sm leading-5"><%= t("share_management.fields.share_remote_upload_assets", default: "Upload embedded assets") %></span>
              </label>
            </div>
          </details>
        </form>
      </section>

      <section data-share-management-target="tabPanel" data-tab-panel="publishing" class="space-y-4 hidden">
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wide text-[var(--theme-text-secondary)]"><%= t("share_management.tabs.publishing", default: "Publishing Overview") %></h3>
          <p class="text-xs text-[var(--theme-text-muted)] mt-1"><%= t("share_management.publishing_subtitle", default: "Review published notes, copy links, open their local files, or delete individual shares.") %></p>
        </div>

        <div data-share-management-target="publishedLoading" class="rounded-lg border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] p-4 text-sm text-[var(--theme-text-muted)] hidden">
          <%= t("share_management.published_loading", default: "Loading published notes...") %>
        </div>

        <div data-share-management-target="publishedEmpty" class="rounded-lg border border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] p-4 text-sm text-[var(--theme-text-muted)] hidden">
          <%= t("share_management.published_empty", default: "No published notes were found.") %>
        </div>

        <div data-share-management-target="publishedList" class="hidden"></div>
      </section>
    </div>

    <div class="flex flex-wrap items-center justify-between gap-3 px-6 py-4 bg-[var(--theme-bg-secondary)] rounded-b-lg border-t border-[var(--theme-border)]">
      <p data-share-management-target="feedback" class="text-xs text-[var(--theme-text-muted)]">
        <%= t("share_management.ready", default: "Adjust settings, recheck the connection, or clear published remote shares.") %>
      </p>
      <div class="flex flex-wrap gap-2 ml-auto">
        <button type="button" data-share-management-target="recheckButton" data-action="click->share-management#recheck" class="px-4 py-2 text-sm rounded bg-transparent hover:bg-[var(--theme-bg-hover)] text-[var(--theme-text-secondary)] border border-[var(--theme-border)]">
          <%= t("share_management.recheck", default: "Reconnect / Recheck") %>
        </button>
        <button type="button" data-share-management-target="deleteButton" data-action="click->share-management#deleteAllShares" class="px-4 py-2 text-sm rounded bg-transparent transition-colors hover:bg-red-500/15 hover:border-red-500/40 text-red-600 dark:text-red-400 border border-red-500/30">
          <%= t("share_management.delete_all", default: "Delete all shared notes") %>
        </button>
        <button type="button" data-action="click->share-management#close" class="px-4 py-2 text-sm rounded bg-transparent hover:bg-[var(--theme-bg-hover)] text-[var(--theme-text-secondary)]">
          <%= t("common.close") %>
        </button>
        <button type="button" data-share-management-target="saveButton" data-action="click->share-management#save" class="px-4 py-2 text-sm rounded bg-[var(--theme-accent)] text-[var(--theme-accent-text)] hover:bg-[var(--theme-accent-hover)]">
          <%= t("common.save") %>
        </button>
      </div>
    </div>
  </dialog>
</div>
